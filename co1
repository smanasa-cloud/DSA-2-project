public class RouteNode {
    int routeId;
    String destination;
    RouteNode left, right;

    public RouteNode(int routeId, String destination) {
        this.routeId = routeId;
        this.destination = destination;
    }

    // --- Tree Logic inside the same class ---
    private static RouteNode insert(RouteNode node, int routeId, String destination) {
        if (node == null) {
            return new RouteNode(routeId, destination);
        }
        if (routeId < node.routeId) {
            node.left = insert(node.left, routeId, destination);
        } else if (routeId > node.routeId) {
            node.right = insert(node.right, routeId, destination);
        }
        return node;
    }

    private static void inorder(RouteNode node) {
        if (node != null) {
            inorder(node.left);
            System.out.println("Route ID: " + node.routeId + " -> " + node.destination);
            inorder(node.right);
        }
    }

    // --- The Main Method is now here, so it won't crash! ---
    public static void main(String[] args) {
        RouteNode root = null;

        // Adding routes
        root = insert(root, 30, "London");
        root = insert(root, 10, "New York");
        root = insert(root, 20, "Tokyo");

        // Print sorted result
        System.out.println("--- Sorted Travel Schedule ---");
        inorder(root);
    }
}
